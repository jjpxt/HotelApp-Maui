<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelApp_Maui.Views.HospedagemContratada"
             Title="HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">
    
    <VerticalStackLayout VerticalOptions="Center">
        <Label Text="Suite super luxo"
               TextColor="{StaticResource Primary}"
               FontFamily="ChangoRegular"
               FontSize="41"
               HorizontalTextAlignment="Center"/>

        <Frame Margin="10">
            <HorizontalStackLayout>

                <HorizontalStackLayout>
                    <Label Text="Adultos: "/>
                    <Label Text=" 2" TextColor="{StaticResource Primary}" />
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <Label Text=" Crianças:"/>
                    <Label Text=" 1" TextColor="{StaticResource Primary}"/>
                </HorizontalStackLayout>
                
            </HorizontalStackLayout>
        </Frame>

        <Frame Margin="10">
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="auto, auto">
                <Label Grid.Row="0" Grid.Column="0" Text="Check-in: "/>
                <Label Grid.Row="0" Grid.Column="1" Text="Check-out: "/>
                <Label Grid.Row="0" Grid.Column="2" Text="Estadia: "/>

                <Label Grid.Row="1" Grid.Column="0" Text="27/04/2025 "/>
                <Label Grid.Row="1" Grid.Column="1" Text="29/04/2025"/>
                <Label Grid.Row="1" Grid.Column="2" Text="2"/>
            </Grid>
        </Frame>

        <Frame Margin="10">
            <HorizontalStackLayout>
                <Label Text="Valor Total: "/>
                <Label Text=" R$: 750,00"/>
            </HorizontalStackLayout>
        </Frame>

        <Button Text="Voltar" 
                     Clicked="Button_Clicked" 
                     HorizontalOptions="Center" 
                    CornerRadius="20"
                    FontAttributes="Bold" />
        
    </VerticalStackLayout>
    
</ContentPage>