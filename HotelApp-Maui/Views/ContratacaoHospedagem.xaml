<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HotelApp_Maui.Views.ContratacaoHospedagem"
             Title="ContratacaoHospedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="Center" Padding="10">
        <Label 
            Text="Cálculo da Diaria"
            FontFamily="ChangoRegular"
            FontSize="40"
            TextColor="{StaticResource Primary}"
            HorizontalOptions="Center"/>

        <Frame Padding="10">
            <VerticalStackLayout>
                <Grid RowDefinitions="auto, auto" ColumnDefinitions="*,*,2*">

                    <Label Text="Adultos:" Grid.Row="0" Grid.Column="0"/>

                    <Label Grid.Row="0" Grid.Column="1" 
                           TextColor="{StaticResource Primary}" 
                           Text="{Binding Value}" BindingContext="{x:Reference stp_adultos}"/>

                    <Stepper Grid.Row="0" Grid.Column="2" 
                             x:Name="stp_adultos"
                             Minimum="0"
                             Maximum="10"
                             Increment="1"/>

                    <Label Text="Crianças:" Grid.Row="1" Grid.Column="0" />

                    <Label Grid.Row="1" Grid.Column="1" 
                           TextColor="{StaticResource Primary}" 
                           Text="{Binding Value}" BindingContext="{x:Reference stp_criancas}"/>

                    <Stepper Grid.Row="1" Grid.Column="2" 
                             x:Name="stp_criancas"
                             Minimum="0"
                             Maximum="10"
                             Increment="1"
                             />

                </Grid>

                <Label Text="Escolha sua suíte"/>
                <Picker x:Name="pck_quarto" Title="Selecione sua Acomodação" ItemDisplayBinding="{Binding Descricao}"/>

                <Frame Padding="10" Margin="10" CornerRadius="12" BorderColor="DarkBlue">
                    <VerticalStackLayout>
                        <Label Text="Período da Estadia"/>

                        <HorizontalStackLayout>
                            <Label Text="Check-in: " Padding="15"/>
                            <DatePicker x:Name="dtpck_checkin"
                                                DateSelected="dtpck_checkin_DateSelected"
                                                Format="dd/MM/yyyy"
                                                BackgroundColor="LightGray"
                                                 />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout>
                            <Label Text="Check-out: " Padding="10"/>
                            <DatePicker x:Name="dtpck_checkout"
                                                Format="dd/MM/yyyy" 
                                                BackgroundColor="LightGray"/>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <Button Text="Avançar"
                        CornerRadius="20"
                        FontAttributes="Bold" 
                        Clicked="Button_Clicked"
                        HorizontalOptions="Center"/>


            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>

</ContentPage>